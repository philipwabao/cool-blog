---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("posts", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const fmt = (d: Date) => d.toISOString().slice(0, 10).replace(/-/g, ".");
const total = posts.length;
---
<BaseLayout
  title="Writing"
  description="Essays and notes by Philip Abao."
  mark="— writing index —"
  colophonLeft={`entries · ${total}`}
  colophonRight="ordered · newest first"
>
  <section class="section">
    <div class="section-head">
      <span class="section-num">§</span>
      <h2 class="section-title">All writing</h2>
      <span class="section-rule"></span>
    </div>

    {total === 0 ? (
      <p class="empty">Nothing here yet.</p>
    ) : (
      <ul class="post-list">
        {posts.map((p) => (
          <li>
            <span class="post-date">{fmt(p.data.pubDate)}</span>
            <span class="post-title">
              <a href={`/posts/${p.id}/`}>{p.data.title}</a>
            </span>
            <span class="post-tag">{p.data.tag ?? "essay"}</span>
          </li>
        ))}
      </ul>
    )}
  </section>
</BaseLayout>
