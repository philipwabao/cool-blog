---
import { getCollection, render } from "astro:content";
import PostLayout from "../../layouts/PostLayout.astro";

export async function getStaticPaths() {
  const posts = await getCollection("posts", ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, remarkPluginFrontmatter } = await render(post);

const readingTime: string | undefined = remarkPluginFrontmatter?.minutesRead;
---
<PostLayout
  title={post.data.title}
  description={post.data.description}
  pubDate={post.data.pubDate}
  tag={post.data.tag}
  category={post.data.category}
  readingTime={readingTime}
>
  <h1 class={`post-title-hero${post.data.centerHero ? " is-centered" : ""}`}>{post.data.title}</h1>
  <p class={`post-desc${post.data.centerHero ? " is-centered" : ""}`}>{post.data.description}</p>
  <Content />
</PostLayout>
