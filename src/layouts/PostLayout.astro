---
import BaseLayout from "./BaseLayout.astro";

interface Props {
  title: string;
  description?: string;
  pubDate: Date;
  tag?: string;
  slug: string;
  readingTime?: string;
}

const { title, description, pubDate, tag, slug, readingTime } = Astro.props;

const dateFmt = pubDate.toISOString().slice(0, 10).replace(/-/g, "·");
const isMemoriam = tag === "in memoriam";
---
<BaseLayout
  title={title}
  description={description}
  mark={`— ${tag ?? "essay"} —`}
  tag={description}
  colophonRight={`published · ${dateFmt}${readingTime ? ` · ${readingTime}` : ""}`}
  prose
>
  <!-- Reading progress (only meaningful on long articles) -->
  <div id="reading-progress" class="reading-progress" style="width: 0%"></div>

  <article class={isMemoriam ? "memoriam" : undefined} transition:name="post-article">
    <slot />
  </article>

  <a href="/writing" class="back-link" style="margin-top: 56px; display: inline-flex;">← back to writing</a>
</BaseLayout>

<script>
  // Reading progress — lightweight, no deps
  const progress = document.getElementById('reading-progress') as HTMLDivElement | null;
  if (progress) {
    const update = () => {
      const article = document.querySelector('article');
      if (!article) return;
      const rect = article.getBoundingClientRect();
      const total = article.scrollHeight - window.innerHeight;
      const scrolled = Math.max(0, window.scrollY - (article.offsetTop || 0));
      const pct = total > 0 ? Math.min(100, Math.max(0, (scrolled / total) * 100)) : 0;
      progress.style.width = pct + '%';
    };
    window.addEventListener('scroll', update, { passive: true });
    window.addEventListener('resize', update);
    // initial
    setTimeout(update, 60);
  }
</script>
