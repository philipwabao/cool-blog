---
interface Props {
  variant?: "row" | "stack";
}
const { variant = "row" } = Astro.props;
const links = [
  {
    href: "mailto:philip.abao@outlook.com",
    label: "philip.abao@outlook.com",
    hint: "email",
    icon: "mail",
  },
  {
    href: "https://www.linkedin.com/in/philip-abao/",
    label: "/in/philip-abao",
    hint: "linkedin",
    icon: "linkedin",
  },
  {
    href: "https://x.com/philip_abao",
    label: "@philip_abao",
    hint: "x",
    icon: "x",
  },
];
---
<ul class={`contact contact-${variant}`}>
  {links.map((l) => (
    <li>
      <a
        href={l.href}
        target={l.href.startsWith("http") ? "_blank" : undefined}
        rel={l.href.startsWith("http") ? "noopener noreferrer" : undefined}
        aria-label={l.hint}
      >
        <span class="contact-icon" aria-hidden="true">
          {l.icon === "mail" && (
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="5" width="18" height="14" rx="2" />
              <path d="M3 7l9 6 9-6" />
            </svg>
          )}
          {l.icon === "linkedin" && (
            <svg viewBox="0 0 24 24" fill="currentColor">
              <path d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.86 0-2.14 1.45-2.14 2.95v5.66H9.34V9h3.41v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12zM7.12 20.45H3.56V9h3.56v11.45zM22.23 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.46c.98 0 1.77-.77 1.77-1.72V1.72C24 .77 23.21 0 22.23 0z" />
            </svg>
          )}
          {l.icon === "x" && (
            <svg viewBox="0 0 24 24" fill="currentColor">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
            </svg>
          )}
        </span>
        <span class="contact-label">{l.label}</span>
      </a>
    </li>
  ))}
</ul>
