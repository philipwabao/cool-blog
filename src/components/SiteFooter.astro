---
import Contact from "./Contact.astro";
const year = new Date().getFullYear();
const navItem =
  "font-mono text-[10.5px] uppercase tracking-[0.16em] text-ink-3 transition-colors hover:text-accent";
---
<footer class="mt-20 border-t border-rule-strong pt-8 sm:mt-24">
  <div class="flex flex-col gap-7 sm:flex-row sm:items-start sm:justify-between">
    <div class="min-w-0">
      <p class="font-mono text-[11px] uppercase tracking-[0.18em] text-ink-2">Philip Abao</p>
      <div class="mt-4">
        <Contact variant="row" />
      </div>
    </div>

    <nav class="flex flex-wrap items-baseline gap-x-6 gap-y-2" aria-label="Footer">
      <a href="/writing" class={navItem}>Writing</a>
      <a href="/about" class={navItem}>About</a>
      <a href="/rss.xml" rel="alternate" class={navItem}>RSS</a>
    </nav>
  </div>

  <p class="mt-10 border-t border-rule pt-4 font-mono text-[10px] tracking-[0.08em] text-ink-3">
    © {year} Philip Abao
  </p>
</footer>
