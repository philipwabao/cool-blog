---
/**
 * Tribute.astro
 * Reusable, theme-safe version of the "Inspired by" list used in research notes.
 * Renders the exact .tribute markup so existing CSS applies unchanged.
 *
 * Usage in MDX:
 *   import { Tribute } from '../../components/mdx/Tribute.astro';
 *   <Tribute authors={[
 *     { name: "Geoffrey Hinton", note: "deep learning" },
 *     ...
 *   ]} />
 */
export interface Props {
  authors?: Array<{ name: string; note?: string }>;
}

const { authors = [] } = Astro.props;
---

<div class="tribute">
  <ol>
    {authors.length > 0 ? (
      authors.map((a) => (
        <li>
          <span class="t-name">{a.name}</span>
          {a.note && <span class="t-note">{a.note}</span>}
        </li>
      ))
    ) : (
      <slot />
    )}
  </ol>
</div>